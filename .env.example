# ═══════════════════════════════════════════════════════════════════
#  PensionistaAgent — Configuração de LLM Provider
# ═══════════════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha UMA das chaves abaixo.
#   cp .env.example .env
#
# O sistema auto-detecta qual provider usar (prioriza gratuitos).
# Ou force com: LLM_PROVIDER=groq | gemini | anthropic
# ═══════════════════════════════════════════════════════════════════

# ── OPÇÃO 1: Groq (GRÁTIS — 30 req/min) ─────────────────────────
# Crie conta em: https://console.groq.com/keys
# Modelos: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
GROQ_API_KEY=SUA_CHAVE_GROQ_AQUI

# ── OPÇÃO 2: Google Gemini (GRÁTIS — 15 req/min) ────────────────
# Crie conta em: https://aistudio.google.com/apikey
# Modelos: gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
GEMINI_API_KEY=SUA_CHAVE_GEMINI_AQUI

# ── OPÇÃO 3: Anthropic (PAGO) ───────────────────────────────────
# Crie conta em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-SUA_CHAVE_AQUI

# ── Configurações opcionais ──────────────────────────────────────
# LLM_PROVIDER=groq          # Força um provider específico
# LLM_MODEL=llama-3.3-70b-versatile  # Override do modelo padrão
